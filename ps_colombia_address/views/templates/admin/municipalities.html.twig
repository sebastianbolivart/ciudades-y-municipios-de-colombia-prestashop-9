{#
  Municipality dataset manager template.

  Features:
    • Department filter dropdown (server-side)
    • Paginated municipality table
    • CSV import form (file upload + CSRF token)

  All dynamic values are auto-escaped by Twig (default htmlspecialchars).
  File-upload form uses POST + enctype="multipart/form-data".
#}
{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block title %}{{ 'Municipality Dataset'|trans({}, 'Modules.PsColombiaAddress.Admin') }}{% endblock %}

{% block content %}
<div class="page-head">
  <div class="page-head-top">
    <div class="page-title">
      <span class="title-meta">Colombia Address Manager</span>
      <h2>{{ 'Municipality Dataset'|trans({}, 'Modules.PsColombiaAddress.Admin') }}</h2>
    </div>
  </div>
</div>

<div class="content-div">

  {# Flash messages #}
  {% for label, messages in app.flashes %}
    {% for message in messages %}
      <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible" role="alert">
        <button type="button" class="close" data-dismiss="alert" aria-label="{{ 'Close'|trans }}">
          <span aria-hidden="true">&times;</span>
        </button>
        {{ message|e }}
      </div>
    {% endfor %}
  {% endfor %}

  <div class="row">

    {# CSV Import card #}
    <div class="col-md-5">
      <div class="card mb-4">
        <div class="card-header">
          <h3 class="card-header-title">{{ 'Import CSV Dataset'|trans({}, 'Modules.PsColombiaAddress.Admin') }}</h3>
        </div>
        <div class="card-body">
          <p class="text-muted">
            {{ 'Upload a CSV file with columns: department, municipality, postal_code, dane_code, latitude, longitude.'|trans({}, 'Modules.PsColombiaAddress.Admin') }}
          </p>
          <p>
            {{ 'Current records:'|trans({}, 'Modules.PsColombiaAddress.Admin') }}
            <strong>{{ datasetCount }}</strong>
          </p>

          <form method="post"
                action="{{ path('admin_colombia_address_import') }}"
                enctype="multipart/form-data">

            {# CSRF token #}
            <input type="hidden" name="_token" value="{{ csrf_token('colombia_address_import') }}">

            <div class="form-group">
              <label for="csv_file">
                {{ 'CSV file (max 10 MB)'|trans({}, 'Modules.PsColombiaAddress.Admin') }}
              </label>
              <input type="file"
                     id="csv_file"
                     name="csv_file"
                     accept=".csv,text/csv"
                     class="form-control-file"
                     required>
            </div>

            <button type="submit" class="btn btn-warning">
              {{ 'Import & Replace Dataset'|trans({}, 'Modules.PsColombiaAddress.Admin') }}
            </button>
          </form>
        </div>
      </div>
    </div>{# /col #}

    {# Department filter #}
    <div class="col-md-7">
      <div class="card mb-4">
        <div class="card-header">
          <h3 class="card-header-title">{{ 'Browse by Department'|trans({}, 'Modules.PsColombiaAddress.Admin') }}</h3>
        </div>
        <div class="card-body">
          <form method="get" action="{{ path('admin_colombia_address_municipalities') }}">
            <div class="form-row align-items-end">
              <div class="col-sm-8">
                <label for="dept_filter">{{ 'Department'|trans({}, 'Modules.PsColombiaAddress.Admin') }}</label>
                <select id="dept_filter" name="department" class="form-control">
                  <option value="">— {{ 'Select a department'|trans({}, 'Modules.PsColombiaAddress.Admin') }} —</option>
                  {% for dept in departments %}
                    <option value="{{ dept|e }}"{{ selectedDept == dept ? ' selected' : '' }}>
                      {{ dept|e }}
                    </option>
                  {% endfor %}
                </select>
              </div>
              <div class="col-sm-4">
                <button type="submit" class="btn btn-primary btn-block">
                  {{ 'Filter'|trans({}, 'Admin.Actions') }}
                </button>
              </div>
            </div>
          </form>
        </div>
      </div>

      {# Municipality results #}
      {% if municipalities is not empty %}
      <div class="card">
        <div class="card-header">
          <h3 class="card-header-title">
            {{ 'Municipalities in'|trans({}, 'Modules.PsColombiaAddress.Admin') }}
            <strong>{{ selectedDept|e }}</strong>
            ({{ municipalities|length }})
          </h3>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-striped table-sm mb-0">
              <thead class="thead-light">
                <tr>
                  <th>{{ 'Municipality'|trans({}, 'Modules.PsColombiaAddress.Admin') }}</th>
                  <th>{{ 'Postal Code'|trans({}, 'Modules.PsColombiaAddress.Admin') }}</th>
                  <th>{{ 'DANE Code'|trans({}, 'Modules.PsColombiaAddress.Admin') }}</th>
                  <th>{{ 'Latitude'|trans({}, 'Modules.PsColombiaAddress.Admin') }}</th>
                  <th>{{ 'Longitude'|trans({}, 'Modules.PsColombiaAddress.Admin') }}</th>
                </tr>
              </thead>
              <tbody>
                {% for muni in municipalities %}
                <tr>
                  <td>{{ muni.name|e }}</td>
                  <td><code>{{ muni.postal_code|e }}</code></td>
                  <td><code>{{ muni.dane_code|e }}</code></td>
                  <td>{{ muni.latitude|e }}</td>
                  <td>{{ muni.longitude|e }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      </div>
      {% elseif selectedDept is not empty %}
      <div class="alert alert-info">
        {{ 'No municipalities found for this department.'|trans({}, 'Modules.PsColombiaAddress.Admin') }}
      </div>
      {% endif %}

    </div>{# /col #}
  </div>{# /row #}

  <div class="mt-3">
    <a href="{{ path('admin_colombia_address_index') }}" class="btn btn-outline-secondary btn-sm">
      ← {{ 'Back to configuration'|trans({}, 'Modules.PsColombiaAddress.Admin') }}
    </a>
  </div>

</div>{# /content-div #}
{% endblock %}
